ressed_b(): #doprava\n    global direction\n    direction = (-direction[1], direction[0])\ninput.on_button_pressed(Button.A, on_button_pressed_b)\n\ndef on_every_interval():\n    led.unplot(snake[0][0], snake[0][1])\n    snake.pop(0)\n    snake.append((snake[-1][0] + direction[0], snake[-1][1] + direction[1]))\n    led.plot(snake[-1][0], snake[-1][1])\nloops.every_interval(500, on_every_interval)\n","pxt.json":"{\n    \"name\": \"snake\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}},{"timestamp":1773213874681,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"every_interval\" x=\"20\" y=\"20\"><value name=\"interval\"><shadow type=\"longTimePicker\"><field name=\"ms\">500</field></shadow></value></block><block type=\"device_button_event\" x=\"263\" y=\"20\"><field name=\"NAME\">Button.A</field></block></xml>","main.ts":"","README.md":"","main.py":"snake_brightness = 100\napple_brightness = 255\n\ndirection = (1, 0)\nsnake = [(0, 2), (1, 2), (2, 2)]\napple = (0, 0)\n\ndef spawn_apple():\n    global apple\n    placed = False\n    while not placed:\n        apple = (randint(0, 4), randint(0, 4))\n        if not apple in snake:\n            placed = True\n    led.plot_brightness(apple[0], apple[1], apple_brightness)\n\nbasic.clear_screen()\nfor i in snake:\n    led.plot_brightness(i[0], i[1], snake_brightness)\nspawn_apple()\n\ndef on_button_pressed_a(): #dolava\n    global direction\n    direction = (direction[1], -direction[0])\ninput.on_button_pressed(Button.A, on_button_pressed_a)\n\ndef on_button_pressed_b(): #doprava\n    global direction\n    direction = (-direction[1], direction[0])\ninput.on_button_pressed(Button.B, on_button_pressed_b)\n\ndef on_every_interval():\n    global snake\n    last_index = len(snake) - 1\n    new_head_x = snake[last_index][0] + direction[0]\n    new_head_y = snake[last_index][1] + direction[1]\n    \n    if (new_head_x, new_head_y) == apple:\n        spawn_apple()\n    else:\n        led.unplot(snake[0][0], snake[0][1])\n        snake.pop(0)\n\n    snake.append((new_head_x, new_head_y))\n    led.plot_brightness(new_head_x, new_head_y, snake_brightness)\n    \nloops.every_interval(500, on_every_interval)","pxt.json":"{\n    \"name\": \"snake\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\"\n}\n"}}],"shares":[],"lastSaveTime":1773215479249}